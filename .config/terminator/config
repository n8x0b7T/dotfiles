[global_config]
  title_transmit_fg_color = "#c0bfbc"
  title_transmit_bg_color = "#000000"
  title_receive_fg_color = "#c0bfbc"
  title_inactive_bg_color = "#000000"
  suppress_multiple_term_dialog = True
[keybindings]
  split_vert = <Primary><Shift>h
[profiles]
  [[default]]
    cursor_color = "#aaaaaa"
    scrollback_infinite = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
